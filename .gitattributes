# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Standard patterns for Rust projects
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.lib binary
*.dll binary
*.exe binary
