# SecOps Port Scanner Configuration Template
# Copy this file to .env and adjust variables as needed

# --- Web UI Settings ---
# The port the web server will listen on
PORT=3000
HOST=0.0.0.0

# --- Scan Settings ---
# Default timeout for each port scan in milliseconds
DEFAULT_TIMEOUT=1000

# Default number of concurrent tasks
DEFAULT_CONCURRENCY=500

# --- Logging ---
# RUST_LOG level (error, warn, info, debug, trace)
RUST_LOG=info
